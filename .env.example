# ============================================================
# Agent Proptech — File mẫu biến môi trường
# ------------------------------------------------------------
# Copy file này thành .env rồi điền giá trị thật.
# TUYỆT ĐỐI KHÔNG commit .env lên git.
# ============================================================

# ---------- LLM ----------
# Bắt buộc. Lấy key tại https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Mô hình LLM mặc định (có thể đổi sang claude-sonnet-4-6 nếu cần rẻ hơn)
LLM_MODEL=claude-opus-4-7

# ---------- Embedding (cho RAG) ----------
# Bắt buộc khi bật RAG. Để trống ở MVP nếu chưa cần.
VOYAGE_API_KEY=
# Hoặc dùng OpenAI embedding:
OPENAI_API_KEY=

# ---------- Database ----------
# Postgres + pgvector. Có thể dùng Supabase / Neon free tier khi deploy.
# Ở MVP local có thể bỏ trống — agent-engine sẽ chạy in-memory.
DATABASE_URL=postgresql://user:password@localhost:5432/agent_proptech

# ---------- Web Dashboard ----------
# URL của agent-engine — dashboard sẽ gọi vào đây.
NEXT_PUBLIC_AGENT_ENGINE_URL=http://localhost:8000

# ---------- Tích hợp kênh (giai đoạn 2) ----------
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_VERIFY_TOKEN=

# ---------- Chatwoot (Hộp thư đa kênh + Webhook bot) ----------
# Dùng cho: webhook bot (/webhook/chatwoot) + Hộp thư đa kênh (/admin/inbox/*) +
# nối hội thoại vào Hồ sơ 360°. Trống CHATWOOT_API_TOKEN → các tính năng Chatwoot
# hiện hướng dẫn cấu hình (KHÔNG lỗi 500); hội thoại chat web nội bộ vẫn chạy.
# Token: Chatwoot → Profile Settings → Access Token (hoặc token Agent Bot).
CHATWOOT_API_TOKEN=
# ID tài khoản Chatwoot (xem trên URL: /app/accounts/<id>/...). Mặc định 1.
CHATWOOT_ACCOUNT_ID=1
# URL Chatwoot self-host.
CHATWOOT_BASE_URL=https://chat.eurowindowlightcity.net

# ---------- Cấu hình agent ----------
# Ngưỡng điểm intent để chuyển lead sang trạng thái 'hot' và bàn giao saleman
LEAD_HOT_SCORE_THRESHOLD=70

# Bật/tắt chế độ mock (không gọi LLM thật — dùng khi test)
USE_MOCK_LLM=false

# ---------- n8n REST API (trang admin "Automation") ----------
# Cho phép admin LIỆT KÊ / BẬT-TẮT / xem lịch sử chạy toàn bộ workflow n8n.
# Base URL trống → tự dùng https://n8n.eurowindowlightcity.net.
N8N_API_URL=
# Tạo key trong n8n: Settings → n8n API → Create an API key. Trống → trang
# Automation hiện hướng dẫn set key (không lỗi 500).
N8N_API_KEY=

# ---------- Telegram (bot sale) ----------
# Token bot sale @BotFather. Trống → tính năng alert/briefing Telegram tắt.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=elc_sale_bot

# ---------- OpenClaw God-Mode Bridge (trợ lý AI CEO, prefix /openclaw) ----------
# Token "vạn năng" cho service OpenClaw gọi /openclaw/*. Sinh: openssl rand -hex 32.
# Trống → toàn bộ /openclaw/* trả 403 (fail-closed). TUYỆT ĐỐI không commit.
OPENCLAW_GOD_TOKEN=
# Bot Telegram riêng của CEO (@elc_ceo_bot). Trống → fallback TELEGRAM_BOT_TOKEN.
OPENCLAW_TELEGRAM_BOT_TOKEN=
# chat_id Telegram của CEO — mặc định nhận tin /openclaw/telegram/send + announce.
OPENCLAW_CEO_CHAT_ID=
# Anthropic Admin API key cho /openclaw/cost/anthropic. Trống → {"configured": false}.
ANTHROPIC_ADMIN_KEY=
# Railway API token cho /openclaw/platforms/restart + /openclaw/logs. Trống → 503.
RAILWAY_API_TOKEN=
# (Tuỳ chọn) map service id để restart: RAILWAY_SERVICE_<TÊN_HOA>_ID, RAILWAY_ENV_ID.

# ---------- SMTP (gửi email qua /openclaw/email/send + /openclaw/announce) ----------
# Trống SMTP_HOST → endpoint email trả 503 (chưa cấu hình). KHÔNG commit mật khẩu.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# ---------- Dify (bộ não tri thức RAG — thay thế Open Notebook) ----------
# Dify self-host (LLM platform + RAG). Chatbot tư vấn + OpenClaw gọi qua đây.
# ĐỂ TRỐNG → mọi tính năng Dify TẮT an toàn: chatbot fallback Claude trực tiếp,
# tool MCP dify_knowledge_query trả "Dify chưa cấu hình" (KHÔNG crash).
# Base URL Dify (KHÔNG kèm /v1 — client tự ghép). Vd: https://dify.eurowindowlightcity.net
DIFY_API_URL=
# App API key của ứng dụng Chatbot/Agent trong Dify (bắt đầu app-...).
DIFY_API_KEY=
# (Tuỳ chọn) API key Knowledge Base / Datasets (bắt đầu dataset-...) — chỉ cần khi
# truy hồi (retrieve) hoặc đẩy tài liệu vào knowledge base qua API.
DIFY_DATASET_API_KEY=
# (Tuỳ chọn) dataset mặc định để truy hồi khi không truyền dataset_id.
DIFY_DATASET_ID=
# (Tuỳ chọn) URL hiển thị Dify trên trang nền tảng admin + health-check.
PLATFORM_DIFY_URL=https://dify.eurowindowlightcity.net
