# ============================================================
# Agent Proptech — File mẫu biến môi trường
# ------------------------------------------------------------
# Copy file này thành .env rồi điền giá trị thật.
# TUYỆT ĐỐI KHÔNG commit .env lên git.
# ============================================================

# ---------- LLM ----------
# Bắt buộc. Lấy key tại https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Mô hình LLM mặc định (có thể đổi sang claude-sonnet-4-6 nếu cần rẻ hơn)
LLM_MODEL=claude-opus-4-7

# ---------- Embedding (cho RAG) ----------
# Bắt buộc khi bật RAG. Để trống ở MVP nếu chưa cần.
VOYAGE_API_KEY=
# Hoặc dùng OpenAI embedding:
OPENAI_API_KEY=

# ---------- Database ----------
# Postgres + pgvector. Có thể dùng Supabase / Neon free tier khi deploy.
# Ở MVP local có thể bỏ trống — agent-engine sẽ chạy in-memory.
DATABASE_URL=postgresql://user:password@localhost:5432/agent_proptech

# ---------- Web Dashboard ----------
# URL của agent-engine — dashboard sẽ gọi vào đây.
NEXT_PUBLIC_AGENT_ENGINE_URL=http://localhost:8000

# ---------- Tích hợp kênh (giai đoạn 2) ----------
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_VERIFY_TOKEN=

# ---------- Cấu hình agent ----------
# Ngưỡng điểm intent để chuyển lead sang trạng thái 'hot' và bàn giao saleman
LEAD_HOT_SCORE_THRESHOLD=70

# Bật/tắt chế độ mock (không gọi LLM thật — dùng khi test)
USE_MOCK_LLM=false
