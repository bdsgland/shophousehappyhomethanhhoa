          }
        ]
      ]
    },
    "Chờ 5 phút": {
      "main": [
        [
          {
            "node": "Check contacted_at",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check contacted_at": {
      "main": [
        [
          {
            "node": "Sale chưa phản hồi?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Sale chưa phản hồi?": {
      "main": [
        [
          {
            "node": "Telegram — Escalate Manager",
            "type": "main",
            "index": 0
          },
          {
            "node": "Email backup (bật khi Telegram lỗi)",
            "type": "main",
