            "index": 0
          }
        ]
      ]
    },
    "Tách users": {
      "main": [
        [
          {
            "node": "Claude — gen greeting",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Claude — gen greeting": {
      "main": [
        [
          {
            "node": "Email chúc mừng",
            "type": "main",
            "index": 0
          },
          {
            "node": "Chatwoot birthday msg",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {},
  "meta": {},
  "tags": []
}